# ============================================================

*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# ============================================================
# IDE directories
# Generated automatically by IDEs
# ============================================================

.vs/
.idea/
.vscode/
*.code-workspace

# ============================================================
# Compiled object files
# Intermediate build artifacts
# ============================================================

# Dependency and prerequisite files
*.d

*.o
*.obj
*.lo
*.slo

# ============================================================
# Precompiled headers
# Used by compilers to speed up builds
# ============================================================

*.gch
*.pch

# ============================================================
# Linker intermediate files
# ============================================================

*.ilk

# ============================================================
# Debugging symbols and debug databases
# ============================================================

*.pdb
*.dwo

# ============================================================
# Dynamic libraries (shared libraries)
# ============================================================

*.so
*.so.*
*.dll
*.dylib

# ============================================================
# Static libraries
# ============================================================

*.a
*.lib
*.la
*.lai

# ============================================================
# Executables and application bundles
# ============================================================

*.exe
*.out
*.app

# Fortran modules (sometimes generated by toolchains)
*.mod
*.smod


# Build directories
build/
Build/
build-*/
output/
output-*/
out/

