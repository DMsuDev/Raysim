# CMake generated files
# ============================================================

CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
compile_commands.json

# ============================================================
# Generated documentation
# ============================================================

DoxygenFiles/
Doxyfile
*.dox

# ============================================================
# Temporary and backup files
# ============================================================

*.tmp
*.log
*.bak
*.swp

# ============================================================
# Test and cache directories
# ============================================================

Testing/
.cache/

