{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "RS_BUILD_EXAMPLES": "ON",
        "RS_ENABLE_COVERAGE": "OFF"
      }
    },

    {
      "name": "ninja",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja"
    },

    {
      "name": "msvc",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel"
      }
    },
    {
      "name": "debug",
      "inherits": "ninja",
      "displayName": "Debug (Ninja)",
      "binaryDir": "${sourceDir}/build/ninja/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RS_ENABLE_SANITIZERS": "ON",
        "RS_ENABLE_ASAN": "ON",
        "RS_ENABLE_UBSAN": "ON",
        "RS_ENABLE_TSAN": "OFF",
        "RS_ENABLE_MSAN": "OFF",
        "RS_ENABLE_LTO": "OFF"
      }
    },
    {
      "name": "release",
      "inherits": "ninja",
      "displayName": "Release (Ninja)",
      "binaryDir": "${sourceDir}/build/ninja/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RS_ENABLE_SANITIZERS": "OFF",
        "RS_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "msvc-debug",
      "inherits": "msvc",
      "displayName": "Debug (MSVC)",
      "binaryDir": "${sourceDir}/build/msvc/debug",
      "cacheVariables": {
        "RS_ENABLE_SANITIZERS": "ON",
        "RS_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "msvc-release",
      "inherits": "msvc",
      "displayName": "Release (MSVC)",
      "binaryDir": "${sourceDir}/build/msvc/release",
      "cacheVariables": {
        "RS_ENABLE_SANITIZERS": "OFF",
        "RS_ENABLE_LTO": "OFF"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "configuration": "Release"
    }
  ]
}
